{
  "name": "mero-uni",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "db:generate": "NODE_OPTIONS=--experimental-require-module prisma generate",
    "seed:universities": "bun run scripts/seed-universities.ts",
