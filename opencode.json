{
	"$schema": "https://opencode.ai/config.json",
	"mcp": {
		"shadcn": {
			"type": "local",
			"command": ["npx", "shadcn@latest", "mcp"],
			"enabled": true
		},
		"prisma": {
			"type": "local",
			"command": ["npx", "-y", "prisma", "mcp"]
		},
		"nextjs": {
			"type": "local",
			"command": ["npx", "-y", "next-devtools-mcp@latest"]
		}
	}
}
